# Database — inside docker compose use db:5432; running locally against Docker Postgres use localhost:5432
DATABASE_URL=postgresql://eb:eb@db:5432/eb_insights

# Auth — generate with `openssl rand -base64 48`
JWT_SECRET=change-me-generate-with-openssl-rand-base64-48

# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:8081

# pino level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

PORT=3000
